{
  "info": {
    "_postman_id": "b1a7c2e0-1d4f-4a90-9c11-ezequieltorres01",
    "name": "Ezequiel Torres Art - Backend",
    "description": "API collection for the Ezequiel Torres Art backend.\n\nUse the included environments (Local / Cloud) to switch the `baseUrl`.\n\nAuth is Google sign-in only: `POST /api/auth/google` verifies a Firebase ID token and returns the backend's own `{ token, user }`. Postman cannot perform the Google popup, so there are two ways to get a working token:\n\n**A) Test the protected routes (easiest).** Log into the manager in the browser, copy the JWT it stored in localStorage under `token`, and paste it into this environment's `token` variable. Every protected request reuses `{{token}}` via Bearer auth.\n\n**B) Test `POST /api/auth/google` itself.** You need a real Firebase ID token. In the manager (dev build) sign in with Google, open the browser console, run `await getFirebaseIdToken()`, copy the string into this environment's `idToken` variable, then run **Auth > Google Sign-In** — its test script saves the returned `token` and `userId` automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Returns 200 if the server is running."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Google Sign-In",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const res = pm.response.json();",
                  "if (res && res.token) {",
                  "  pm.environment.set('token', res.token);",
                  "  console.log('Saved token to environment.');",
                  "}",
                  "if (res && res.user && res.user._id) {",
                  "  pm.environment.set('userId', res.user._id);",
                  "  console.log('Saved userId:', res.user._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"{{idToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/google",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "google"
              ]
            },
            "description": "Verifies a Firebase Google ID token and returns { token, user }. Set `idToken` in the environment first (sign in on the manager dev build, then run `await getFirebaseIdToken()` in the browser console). Rejects emails outside ALLOWED_GOOGLE_EMAILS (403) or unverified emails (401). The test script saves the returned backend token and userId."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get all users (ADMIN)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users"
              ]
            },
            "description": "Lists every user. ADMIN only."
          },
          "response": []
        },
        {
          "name": "Create user (ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New User\",\n  \"email\": \"newuser@example.com\",\n  \"role\": \"USER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users"
              ]
            },
            "description": "Pre-provisions a user (name, email, role) ahead of their first Google sign-in. No password — identity is verified by Google. ADMIN only."
          },
          "response": []
        },
        {
          "name": "Get user by id (self or ADMIN)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "{{userId}}"
              ]
            },
            "description": "Returns a single user. Allowed for the owner or an admin."
          },
          "response": []
        },
        {
          "name": "Update user (self or ADMIN)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "{{userId}}"
              ]
            },
            "description": "Updates a user. Allowed for the owner or an admin. Non-admins cannot send the `role` field (it returns 403)."
          },
          "response": []
        },
        {
          "name": "Delete user (ADMIN)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "{{userId}}"
              ]
            },
            "description": "Deletes a user by id. ADMIN only."
          },
          "response": []
        }
      ]
    }
  ]
}
