{
  "info": {
    "_postman_id": "d3c9e4a2-3f6b-4c12-be33-ezequieltorres03",
    "name": "Ezequiel Torres Art - Experiences",
    "description": "Requests for the Experiences (\"Trayectoria\") module of the Ezequiel Torres Art backend.\n\nUses the same Local / Cloud environments as the main collection — `baseUrl` and `token` are shared.\n\nFlow:\n1. Run **Auth > Login** in the main collection first so `{{token}}` is saved into the active environment.\n2. **Create experience** stores the new `{{experienceId}}` automatically; the by-id / update / delete requests reuse it.\n\nPermissions: GET endpoints are **public** (no token). POST / PUT / DELETE require an **authenticated** user (ADMIN or USER).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Get all experiences (public)",
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/experiences",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "experiences"
          ]
        },
        "description": "Lists every experience, ordered by `date` descending (most recent first). Public — no token required."
      },
      "response": []
    },
    {
      "name": "Get experience by id (public)",
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/experiences/{{experienceId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "experiences",
            "{{experienceId}}"
          ]
        },
        "description": "Returns a single experience by id. Public. Returns 404 if not found, 400 if the id is malformed."
      },
      "response": []
    },
    {
      "name": "Create experience (auth)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const res = pm.response.json();",
              "if (res && res._id) {",
              "  pm.environment.set('experienceId', res._id);",
              "  console.log('Saved experienceId:', res._id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Fundador de ANIMARTE\",\n  \"date\": \"2018-01-01\",\n  \"description\": \"Creación y gestión de ANIMARTE, espacio de arte y formación en la provincia de Jujuy.\",\n  \"imageUrl\": \"https://res.cloudinary.com/demo/image/upload/v1/animarte.jpg\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/experiences",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "experiences"
          ]
        },
        "description": "Creates an experience. Requires a valid `{{token}}`. `date` accepts an ISO string (coerced to a Date). `imageUrl` is optional. The test script saves the new `_id` as `{{experienceId}}`."
      },
      "response": []
    },
    {
      "name": "Update experience (auth)",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Fundador de ANIMARTE (actualizado)\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/experiences/{{experienceId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "experiences",
            "{{experienceId}}"
          ]
        },
        "description": "Partial update of an experience. Any subset of `title`, `date`, `description`, `imageUrl` is allowed. Requires a valid `{{token}}`."
      },
      "response": []
    },
    {
      "name": "Delete experience (auth)",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/experiences/{{experienceId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "experiences",
            "{{experienceId}}"
          ]
        },
        "description": "Deletes an experience by id. Requires a valid `{{token}}`. Returns a confirmation message plus the deleted document."
      },
      "response": []
    }
  ]
}
