# Copy to .env and fill in. For production, set these in the host's
# environment variables (e.g. Vercel) instead of a committed file.

PORT=3000

# MongoDB connection string. Local Docker example below; for Atlas use the
# connection string from the cluster.
MONGO_URI=mongodb://admin:password123@localhost:27017/portfolio_db?authSource=admin

NODE_ENV=development

# Min 10 chars. Use a long random value in production.
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=1d

# Cloudinary credentials for image uploads (optional; uploads return 503 if unset).
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=

# Firebase Admin service account (Project Settings -> Service Accounts ->
# Generate new private key). Paste the private key with literal \n escapes,
# same as the downloaded JSON, wrapped in quotes.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Comma-separated Google account emails allowed to sign in to the manager.
ALLOWED_GOOGLE_EMAILS=someone@gmail.com,other@gmail.com
